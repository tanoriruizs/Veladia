{
  "manifest_version": 3,
  "name": "Veladia",
  "short_name": "Veladia",
  "version": "1.0.0",
  "description": "Análisis de phishing y reputación de sitios con heurísticas locales. Privacidad total: ningún dato sale de tu navegador.",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-loader-8ZatWCm9.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "resources": [
        "assets/url-utils-zYUBn6H-.js",
        "assets/url-utils-zYUBn6H-.js.map",
        "assets/messages-D11XWm5B.js",
        "assets/messages-D11XWm5B.js.map",
        "assets/content-script.ts-DmXJ0hC8.js",
        "assets/content-script.ts-DmXJ0hC8.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
